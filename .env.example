# ============================================
# Liquidity.ai FinTech — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ── Server ──
PORT=3001

# ── Security ──
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# ── CORS ──
# Use * to allow all origins (for LAN sharing), or a specific URL for production
CORS_ORIGIN=*

# ── Data ──
# Directory where the SQLite database is stored (relative to project root)
DATA_DIR=./data

# -- Email / Mailtrap --
# Sign up at mailtrap.io to get your sandbox credentials
# In your inbox go to Integration tab and select Nodemailer
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_username
MAILTRAP_PASS=your_mailtrap_password
MAIL_FROM=noreply@liquidity.ai
